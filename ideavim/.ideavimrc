let mapleader = ' '

set showmode
set showcmd

set number
set relativenumber

set scrolloff=5
set colorcolumn=80,100,120
set cursorline

set ideajoin

set incsearch
set hlsearch
set ignorecase
set smartcase

set notimeout
noremap Q gq
noremap U <C-r>
noremap _ "_
noremap * "*
noremap + "+

set matchpairs+=<:>

set easymotion
set which-key
set commentary
set highlightedyank
set surround

let g:camelcase_motion = 1
let g:camelcase_motion_verbose = 0
source ~/.ideavimrc_extra/toggle_camelcase_motion.vim

let g:WhichKeyDesc__ = "<Leader><Leader> EasyMotion prefix"

map <Leader>aa <Action>(ShowIntentionActions)
map <Leader>ac <Action>(EditorCompleteStatement)
map <Leader>ad <Action>(EditorDuplicate)
map <Leader>ag <Action>(Generate)
map <Leader>as <Action>(SurroundWith)

let g:WhichKeyDesc_a = "<Leader>a actions"
