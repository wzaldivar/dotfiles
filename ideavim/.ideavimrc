let g:WhichKeyDesc_ac = "<Leader>ac complete statement"
let g:WhichKeyDesc_ad = "<Leader>ad duplicate"
let g:WhichKeyDesc_ag = "<Leader>ag generate"
let g:WhichKeyDesc_as = "<Leader>as surround with"

