map <Leader>tc <Action>(EditorToggleCase)
map <Leader>tf <Action>(ExpandCollapseToggleAction)
noremap <Leader>th :set hlsearch!<CR>
noremap <Leader>ti :set ignorecase!<CR>
noremap <Leader>tm :call ToggleCamelCaseMotion()<CR>
noremap <Leader>tn :set incsearch!<CR>
noremap <Leader>tr :set relativenumber!<CR>
noremap <Leader>ts :let @/=""<CR>:redraw<CR>

